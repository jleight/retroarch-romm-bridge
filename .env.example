# Copy to .env (or set these in your shell, e.g. via mise) for `docker compose up`.

# --- Bridge config ---
# RomM instance base URL (required).
ROMM_BASE_URL=https://romm.example.com

# Service token with scope roms.read; keeps the shared ROM index warm.
# If unset, the index is seeded from the first paired device (needs roms.read).
ROMM_API_TOKEN=rmm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides:
# INDEX_REFRESH_INTERVAL=1h
# PLATFORM_MAP=Nintendo - Game Boy Advance=gba,snes=snes
LOG_LEVEL=info

# --- Caddy (tls profile only) ---
# The domain Caddy serves on and obtains a cert for.
SYNC_SITE_ADDRESS=ra2romm.example.com

# Cloudflare API token with Zone:DNS:Edit for the DNS-01 challenge.
CF_API_TOKEN=
